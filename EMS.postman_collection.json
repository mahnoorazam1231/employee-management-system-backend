{
  "info": {
    "name": "Employee Management System (EMS) API",
    "description": "Postman collection for the EMS backend: Authentication, Employee, Department and Dashboard APIs. Import this along with the 'EMS Local' environment (or edit the baseUrl variable) to get started.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "departmentId", "value": "", "type": "string" },
    { "key": "employeeId", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Super Admin\",\n  \"email\": \"admin@ems.com\",\n  \"password\": \"Admin@123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res && res.data && res.data.token) {",
                  "  pm.collectionVariables.set('token', res.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@ems.com\",\n  \"password\": \"Admin@123\"\n}"
            }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "Departments",
      "item": [
        {
          "name": "Create Department",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res && res.data && res.data._id) {",
                  "  pm.collectionVariables.set('departmentId', res.data._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/departments", "host": ["{{baseUrl}}"], "path": ["departments"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Engineering\",\n  \"description\": \"Builds and maintains all software products\"\n}"
            }
          }
        },
        {
          "name": "List Departments",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/departments", "host": ["{{baseUrl}}"], "path": ["departments"] }
          }
        },
        {
          "name": "Get Department By Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/departments/{{departmentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["departments", "{{departmentId}}"]
            }
          }
        },
        {
          "name": "Update Department",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/departments/{{departmentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["departments", "{{departmentId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated department description\"\n}"
            }
          }
        },
        {
          "name": "Assign Employees To Department",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/departments/{{departmentId}}/assign-employees",
              "host": ["{{baseUrl}}"],
              "path": ["departments", "{{departmentId}}", "assign-employees"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeIds\": [\"{{employeeId}}\"]\n}"
            }
          }
        },
        {
          "name": "Delete Department",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/departments/{{departmentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["departments", "{{departmentId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Employees",
      "item": [
        {
          "name": "Add Employee",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res && res.data && res.data._id) {",
                  "  pm.collectionVariables.set('employeeId', res.data._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/employees", "host": ["{{baseUrl}}"], "path": ["employees"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ayesha Khan\",\n  \"email\": \"ayesha.khan@ems.com\",\n  \"phone\": \"+92-300-1234567\",\n  \"position\": \"Backend Developer\",\n  \"department\": \"{{departmentId}}\",\n  \"salary\": 120000,\n  \"status\": \"active\"\n}"
            }
          }
        },
        {
          "name": "List Employees (search, filter, paginate)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/employees?page=1&limit=10&search=&department={{departmentId}}&status=active",
              "host": ["{{baseUrl}}"],
              "path": ["employees"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "search", "value": "" },
                { "key": "department", "value": "{{departmentId}}" },
                { "key": "status", "value": "active" }
              ]
            }
          }
        },
        {
          "name": "Get Employee By Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/employees/{{employeeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["employees", "{{employeeId}}"]
            }
          }
        },
        {
          "name": "Update Employee",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/employees/{{employeeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["employees", "{{employeeId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"salary\": 125000,\n  \"status\": \"active\"\n}"
            }
          }
        },
        {
          "name": "Delete Employee",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/employees/{{employeeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["employees", "{{employeeId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Dashboard Stats",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/dashboard/stats", "host": ["{{baseUrl}}"], "path": ["dashboard", "stats"] }
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        }
      ]
    }
  ]
}
