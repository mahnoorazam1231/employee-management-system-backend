# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
# Replace <username>, <password>, <cluster-url> and <db-name>
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_this_with_a_long_random_secret_string
JWT_EXPIRES_IN=1d

# CORS - comma separated list of allowed origins (use * for all during development)
CORS_ORIGIN=http://localhost:3000
